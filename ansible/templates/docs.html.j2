    <style>
        /* ── Docs-specific styles (all vars from styles.css) ── */
        .docs-page-hero {
            padding: 7rem 0 3rem;
            background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(163,230,53,.08) 0%, transparent 60%);
            border-bottom: 1px solid var(--border-soft);
        }
        .docs-page-hero h1 {
            font-size: clamp(2rem, 5vw, 3rem);
            font-weight: 800;
            letter-spacing: -.03em;
            margin-bottom: .75rem;
            color: var(--text);
        }
        .docs-page-hero p  { color: var(--text-muted); font-size: 1.1rem; max-width: 540px; margin-top: .5rem; }
        .docs-page-hero .hero-badge { margin-bottom: 1.25rem; }

        .docs-main { padding: 3rem 0 6rem; }

        .docs-layout {
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 4rem;
            align-items: start;
        }

        /* ── Sidebar ── */
        .docs-sidebar { position: sticky; top: 5.5rem; height: fit-content; }

        .docs-sidebar-toggle {
            display: none;
            width: 100%;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-card);
            border: 1px solid var(--border-soft);
            padding: .75rem 1rem;
            border-radius: var(--radius-md);
            color: var(--text);
            font-size: .9375rem;
            font-weight: 500;
            cursor: pointer;
            margin-bottom: .5rem;
            transition: var(--transition);
        }
        .docs-sidebar-toggle:hover { border-color: var(--border); }
        .docs-sidebar-toggle .toggle-icon { color: var(--primary); font-style: normal; }

        .docs-nav { list-style: none; }
        .docs-nav li { margin-bottom: .2rem; }
        .docs-nav a {
            display: block;
            padding: .45rem .875rem;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: var(--radius-sm);
            font-size: .9375rem;
            transition: var(--transition);
            border-left: 2px solid transparent;
        }
        .docs-nav a:hover  { color: var(--text); background: rgba(163,230,53,.05); }
        .docs-nav a.active { color: var(--primary); background: rgba(163,230,53,.08); border-left-color: var(--primary); }

        /* ── Content ── */
        .docs-content { min-width: 0; }
        .docs-content section { margin-bottom: 3.5rem; }

        .docs-content h2 {
            font-size: 1.75rem; font-weight: 700; letter-spacing: -.02em;
            margin-bottom: 1.25rem; padding-bottom: .75rem;
            border-bottom: 1px solid var(--border-soft);
            scroll-margin-top: 6.5rem; color: var(--text);
        }
        .docs-content h3 {
            font-size: 1.1rem; font-weight: 600; color: var(--text);
            margin: 1.75rem 0 .75rem; scroll-margin-top: 6.5rem;
        }
        .docs-content h4 {
            font-size: .8125rem; font-weight: 700; color: var(--text-dim);
            margin: 1.5rem 0 .5rem; text-transform: uppercase; letter-spacing: .09em;
        }
        .docs-content p  { color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; }
        .docs-content ul,
        .docs-content ol  { color: var(--text-muted); padding-left: 1.5rem; margin: .75rem 0 1rem; }
        .docs-content li  { margin-bottom: .375rem; line-height: 1.8; }
        .docs-content a   { color: var(--primary); text-decoration: none; }
        .docs-content a:hover { text-decoration: underline; }

        .docs-content code {
            font-family: 'JetBrains Mono', 'Monaco', monospace;
            font-size: .8125rem;
            background: rgba(163,230,53,.1);
            color: var(--primary-light);
            padding: .15rem .45rem;
            border-radius: .25rem;
            border: 1px solid rgba(163,230,53,.15);
        }

        /* Code blocks */
        .docs-pre-wrap { position: relative; margin: 1.25rem 0; }
        .docs-content pre {
            background: #0b150b;
            border: 1px solid rgba(163,230,53,.15);
            padding: 1.5rem;
            border-radius: var(--radius-lg);
            overflow-x: auto;
            font-family: 'JetBrains Mono', 'Monaco', monospace;
            font-size: .8125rem;
            line-height: 1.7;
            color: #c8e6c8;
            margin: 0;
        }
        .docs-content pre code { background: transparent; color: inherit; padding: 0; border: none; font-size: inherit; }

        .code-copy-btn {
            position: absolute; top: .625rem; right: .625rem;
            background: rgba(163,230,53,.1); border: 1px solid rgba(163,230,53,.2);
            color: var(--text-dim); font-size: .75rem; font-family: inherit;
            padding: .25rem .65rem; border-radius: var(--radius-sm);
            cursor: pointer; transition: var(--transition); opacity: 0;
        }
        .docs-pre-wrap:hover .code-copy-btn { opacity: 1; }
        .code-copy-btn:hover { color: var(--primary); border-color: var(--primary); background: rgba(163,230,53,.15); }

        /* Callouts */
        .callout {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-md);
            border-left: 3px solid;
            margin: 1.25rem 0;
            font-size: .9375rem;
            line-height: 1.7;
        }
        .callout-info { background: rgba(163,230,53,.06); border-color: var(--primary); color: var(--text-muted); }
        .callout-warn { background: rgba(245,158,11,.06); border-color: var(--warning); color: var(--text-muted); }
        .callout strong { color: var(--text); }

        /* ── Responsive ── */
        @media (max-width: 900px) {
            .docs-layout          { grid-template-columns: 1fr; gap: 0; }
            .docs-sidebar         { position: static; margin-bottom: 2rem; }
            .docs-sidebar-toggle  { display: flex; }
            .docs-nav-body.hidden { display: none; }
        }
        @media (max-width: 480px) {
            .docs-page-hero { padding: 6rem 0 2rem; }
            .docs-main      { padding: 1.5rem 0 4rem; }
        }
    </style>
